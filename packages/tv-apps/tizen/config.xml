<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://adegatv.live/AdegaTVLive"
        version="1.0.0"
        viewmodes="fullscreen">

    <tizen:application id="AdegaTVLive.AdegaTVLive" package="AdegaTVLive" required_version="2.3"/>
    <tizen:privilege name="http://tizen.org/privilege/internet"/>
    <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice"/>
    <tizen:privilege name="http://tizen.org/privilege/application.launch"/>
    <tizen:setting screen-orientation="landscape" context-menu="disable" background-support="disable" encryption="disable"/>

    <content src="index.html"/>
    <name>AdegaTV Live</name>
    <icon src="icon.png"/>
    <description>Player de conteúdo promocional para TVs de adegas</description>

    <feature name="http://tizen.org/feature/screen.size.all"/>
</widget>
