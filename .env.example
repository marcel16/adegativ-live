# === DATABASE ===
DATABASE_URL=postgresql://adegatv:adegatv123@postgres:5432/adegatv?schema=public

# === REDIS ===
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# === JWT ===
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_REFRESH_EXPIRATION=7d

# === MINIO (S3-compatible storage) ===
MINIO_ROOT_USER=adegatv
MINIO_ROOT_PASSWORD=adegatv123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=adegatv
MINIO_SECRET_KEY=adegatv123
MINIO_BUCKET=adegatv-media
MINIO_PUBLIC_URL=http://localhost:9002

# === APP ===
APP_NAME=AdegaTV Live
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
ADMIN_URL=http://localhost:3000/admin
PLAYER_URL=http://localhost:3000/player
NODE_ENV=development
PORT=3000

# === TRIAL ===
TRIAL_DAYS=3
PAIRING_CODE_EXPIRY_MINUTES=10

# === STORAGE LIMITS ===
MAX_UPLOAD_SIZE_MB=500
DEFAULT_STORAGE_GB=5

# === ASAAS (opcional) ===
ASAAS_API_KEY=
ASAAS_ENV=sandbox

# === STRIPE (opcional) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=

# === SMTP ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
